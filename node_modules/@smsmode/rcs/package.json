{
  "name": "@smsmode/rcs",
  "version": "1.0.0",
  "description": "Official TypeScript SDK for smsmode© REST API RCS",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "format": "prettier --write src tests",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "deploy": "node scripts/deploy-nexus.cjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/smsmode/rcs-sdk-nodejs.git"
  },
  "homepage": "https://github.com/smsmode/rcs-sdk-nodejs#readme",
  "bugs": {
    "url": "https://github.com/smsmode/rcs-sdk-nodejs/issues"
  },
  "author": {
    "name": "smsmode",
    "url": "https://www.smsmode.com"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "smsmode",
    "rcs",
    "api",
    "sdk",
    "typescript",
    "nodejs",
    "messaging",
    "rest",
    "campaign",
    "webhook",
    "rich-communication"
  ],
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.54.0",
    "vitest": "^4.0.18"
  }
}
